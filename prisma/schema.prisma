generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  password           String
  name               String
  role               String             @default("EMPLOYEE")
  departmentId       String?
  department         Department?          @relation(fields: [departmentId], references: [id])
  managerId          String?
  manager            User?              @relation("UserManager", fields: [managerId], references: [id])
  directReports      User[]             @relation("UserManager")
  goalSheets         GoalSheet[]
  approvals          GoalSheet[]        @relation("ApprovedBy")
  auditLogs          AuditLog[]
  sharedGoalsCreated SharedGoal[]       @relation("SharedGoalCreator")
  checkIns           QuarterlyCheckIn[] @relation("CheckInManager")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Cycle {
  id          String          @id @default(cuid())
  year        Int
  name        String
  isActive    Boolean         @default(true)
  goalSheets  GoalSheet[]
  sharedGoals SharedGoal[]
  windows     CheckInWindow[]
  createdAt   DateTime        @default(now())
}

model CheckInWindow {
  id          String  @id @default(cuid())
  cycleId     String
  cycle       Cycle   @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  period      String
  opensMonth  Int
  closesMonth Int?
  isOpen      Boolean @default(false)

  @@unique([cycleId, period])
}

model GoalSheet {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycleId       String
  cycle         Cycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  status        String    @default("DRAFT")
  isLocked      Boolean   @default(false)
  rejectionNote String?
  submittedAt   DateTime?
  approvedAt    DateTime?
  approvedById  String?
  approvedBy    User?     @relation("ApprovedBy", fields: [approvedById], references: [id])
  goals         Goal[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, cycleId])
}

model SharedGoal {
  id             String    @id @default(cuid())
  cycleId        String
  cycle          Cycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  thrustArea     String
  title          String
  description    String?
  uomType        String
  uomDirection   String    @default("MIN")
  target         Float
  deadline       DateTime?
  createdById    String
  createdBy      User      @relation("SharedGoalCreator", fields: [createdById], references: [id])
  primaryOwnerId String?
  goals          Goal[]
  createdAt      DateTime  @default(now())
}

model Goal {
  id           String             @id @default(cuid())
  goalSheetId  String
  goalSheet    GoalSheet          @relation(fields: [goalSheetId], references: [id], onDelete: Cascade)
  thrustArea   String
  title        String
  description  String?
  uomType      String
  uomDirection String             @default("MIN")
  target       Float
  weightage    Float
  deadline     DateTime?
  isShared     Boolean            @default(false)
  sharedGoalId String?
  sharedGoal   SharedGoal?        @relation(fields: [sharedGoalId], references: [id])
  sortOrder    Int                @default(0)
  checkIns     QuarterlyCheckIn[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model QuarterlyCheckIn {
  id                String    @id @default(cuid())
  goalId            String
  goal              Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  quarter           String
  actualAchievement Float?
  completionDate    DateTime?
  status            String    @default("NOT_STARTED")
  progressScore     Float?
  employeeComment   String?
  managerComment    String?
  managerId         String?
  manager           User?     @relation("CheckInManager", fields: [managerId], references: [id])
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([goalId, quarter])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entityType String
  entityId   String
  action     String
  beforeData String?
  afterData  String?
  metadata   String?
  createdAt  DateTime @default(now())
}

model Escalation {
  id          String    @id @default(cuid())
  type        String
  userId      String
  message     String
  status      String    @default("OPEN")
  escalatedTo String?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}
